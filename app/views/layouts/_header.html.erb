<header class="navbar navbar-dark bg-dark fixed-top">
  <div class="container">
    <%= link_to "sample app", root_path, id: "logo", class: "navbar-brand text-uppercase fw-bold" %>
    <nav>
      <ul class="nav d-flex flex-row gap-3">
        <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link text-white" %></li>
        <li class="nav-item"><%= link_to "Help", help_path, class: "nav-link text-white" %></li>
        <% if logged_in? %>
          <li><%= link_to "Users", "#", class: "nav-link" %></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expended="false" > Account </a>
            <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
              <li><% link_to "Profile", current_user, class: "dropdown-item" %></li>
              <li><%= link_to "Settings", "#", class: "dropdown-item" %></li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <%= link_to "Log out", logout_path, data: { turbo_method: :delete }, class: "dropdown-item" %>
              </li>
            </ul>
          </li>
        <% else %>
          <li><%= link_to "Log in", login_path, class: "nav-link" %></li>
        <% end %>
      </nav>
    </div>
  </header>