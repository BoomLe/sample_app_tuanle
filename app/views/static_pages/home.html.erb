<% provide(:title, "Home") %>
<% if logged_in? %>
  <div class="row">
    <aside class="col-md-4">
      <section class="user_info">
        <%= render "shared/user_info" %>
      </section>
      <section class="micropost_form">
        <%= render "shared/micropost_form" %>
      </section>
    </aside>
    <div class="col-md-8">
      <h3> Bảng tin (Micropost Feed) </h3>
      <%= render "shared/feed" %>
    </div>
  </div>
<% else %>
  <div class="center jumbotron">
    <h1> Chào mừng bạn đến với Sample App! </h1>
    <%= link_to "Đăng ký ngay!", signup_path, class: "btn btn-lg btn-primary" %>
  </div>
<% end %>