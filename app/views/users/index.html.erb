<% provide(:title, "All users") %>
<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <%= form_with url: users_path, method: :get, local: true, class: "d-flex mb-3" do |f| %>
      <%= f.text_field :query, value: params[:query], placeholder: "Tìm kiếm người dùng...", class: "form-control mr-2"%>
      <%= f.submit "Tìm kiếm", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
<h1>All users</h1>
<%= will_paginate %>
<ul class="users">
  <%= render @users %>
</ul>
<%= will_paginate %>